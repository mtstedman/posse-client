{
  "name": "claude-org",
  "version": "4.0.0",
  "description": "SQLite-backed orchestrator for Claude Code with job queue: Researcher + Planner + Dev + Assessor",
  "type": "module",
  "bin": {
    "claude-org": "./orchestrator.js",
    "posse": "./orchestrator.js"
  },
  "scripts": {
    "add": "node orchestrator.js add",
    "queue": "node orchestrator.js queue",
    "plan": "node orchestrator.js plan",
    "run": "node orchestrator.js run",
    "status": "node orchestrator.js status",
    "health": "node orchestrator.js health",
    "dashboard": "node orchestrator.js dashboard",
    "review": "node orchestrator.js review",
    "inject": "node orchestrator.js inject",
    "go": "node orchestrator.js go",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json",
    "check": "npm run lint && npm run typecheck && npm test",
    "test": "node scripts/run-tests.mjs",
    "test:core-only": "node --disable-warning=DEP0040 --test test/core.test.js",
    "test:core-only:fast": "node scripts/run-core-suite.mjs all fast",
    "test:core-only:slow": "node scripts/run-core-suite.mjs all slow",
    "test:core-only:full": "node scripts/run-core-suite.mjs all full",
    "pretest": "node scripts/clean-test-artifacts.mjs",
    "test:quick": "node scripts/run-core-suite.mjs quick fast",
    "test:scheduler": "npm run test:scheduler:fast",
    "test:scheduler:fast": "node scripts/run-core-suite.mjs scheduler fast",
    "test:scheduler:slow": "node scripts/run-core-suite.mjs scheduler slow",
    "test:scheduler:full": "node scripts/run-core-suite.mjs scheduler full",
    "test:atlas": "npm run test:atlas:fast",
    "test:atlas:fast": "node scripts/run-core-suite.mjs atlas fast",
    "test:atlas:slow": "node scripts/run-core-suite.mjs atlas slow",
    "test:atlas:full": "node scripts/run-core-suite.mjs atlas full test/test-atlas-v2-query-planner.test.js",
    "test:providers": "npm run test:providers:fast",
    "test:providers:fast": "node scripts/run-core-suite.mjs provider fast",
    "test:providers:slow": "node scripts/run-core-suite.mjs provider slow",
    "test:providers:full": "node scripts/run-core-suite.mjs provider full test/test-provider-oop.test.js",
    "test:handoff": "npm run test:handoff:fast",
    "test:handoff:fast": "node scripts/run-core-suite.mjs handoff fast",
    "test:handoff:slow": "node scripts/run-core-suite.mjs handoff slow",
    "test:handoff:full": "node scripts/run-core-suite.mjs handoff full",
    "test:planning": "npm run test:planning:fast",
    "test:planning:fast": "node scripts/run-core-suite.mjs planning fast",
    "test:planning:slow": "node scripts/run-core-suite.mjs planning slow",
    "test:planning:full": "node scripts/run-core-suite.mjs planning full",
    "test:toolkit": "npm run test:toolkit:fast",
    "test:toolkit:fast": "node scripts/run-core-suite.mjs toolkit fast",
    "test:toolkit:slow": "node scripts/run-core-suite.mjs toolkit slow",
    "test:toolkit:full": "node scripts/run-core-suite.mjs toolkit full",
    "test:artifacts": "npm run test:artifacts:fast",
    "test:artifacts:fast": "node scripts/run-core-suite.mjs artifact fast",
    "test:artifacts:slow": "node scripts/run-core-suite.mjs artifact slow",
    "test:artifacts:full": "node scripts/run-core-suite.mjs artifact full",
    "test:git": "npm run test:git:fast",
    "test:git:fast": "node scripts/run-core-suite.mjs git fast",
    "test:git:slow": "node scripts/run-core-suite.mjs git slow",
    "test:git:full": "node scripts/run-core-suite.mjs git full test/test-merge-safety.test.js",
    "test:ui": "npm run test:ui:fast",
    "test:ui:fast": "node scripts/run-core-suite.mjs ui fast",
    "test:ui:slow": "node scripts/run-core-suite.mjs ui slow",
    "test:ui:full": "node scripts/run-core-suite.mjs ui full",
    "test:slow": "node scripts/run-core-suite.mjs all slow",
    "test:clean": "node scripts/clean-test-artifacts.mjs"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.14.1-beta.2",
    "better-sqlite3": "12.8.0",
    "node-pty": "^1.1.0",
    "openai": "^4.104.0",
    "qrcode-terminal": "^0.12.0",
    "tree-sitter": "npm:@keqingmoe/tree-sitter@0.26.2"
  },
  "overrides": {
    "tree-sitter": "$tree-sitter"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "4.2.0",
    "tree-sitter-bash": "0.25.1",
    "tree-sitter-c": "0.24.1",
    "tree-sitter-c-sharp": "0.23.1",
    "tree-sitter-cpp": "0.23.4",
    "tree-sitter-go": "0.25.0",
    "tree-sitter-java": "0.23.5",
    "tree-sitter-javascript": "0.23.1",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-php": "0.24.2",
    "tree-sitter-python": "0.25.0",
    "tree-sitter-rust": "0.24.0",
    "tree-sitter-typescript": "0.23.2",
    "usearch": "^2.25.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "typescript": "^6.0.3"
  }
}
