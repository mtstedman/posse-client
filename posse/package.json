{
  "name": "claude-org",
  "version": "4.0.0",
  "description": "SQLite-backed orchestrator for Claude Code with job queue: Researcher + Planner + Dev + Assessor",
  "type": "module",
  "bin": {
    "claude-org": "./orchestrator.js",
    "posse": "./orchestrator.js"
  },
  "scripts": {
    "add": "node orchestrator.js add",
    "queue": "node orchestrator.js queue",
    "plan": "node orchestrator.js plan",
    "run": "node orchestrator.js run",
    "status": "node orchestrator.js status",
    "health": "node orchestrator.js health",
    "dashboard": "node orchestrator.js dashboard",
    "update": "node orchestrator.js update",
    "review": "node orchestrator.js review",
    "inject": "node orchestrator.js inject",
    "go": "node orchestrator.js go",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json",
    "check:protocol": "node scripts/check-control-protocol-drift.mjs",
    "check:vector-fixtures": "node scripts/check-vector-fixture-drift.mjs",
    "fixtures:vector": "node scripts/generate-vector-fixtures.mjs",
    "check:log-secrets": "node scripts/check-log-secrets.mjs",
    "compile:native:encoder": "node scripts/deploy-native.mjs --compile",
    "compile:native:vector": "node scripts/deploy-vector-native.mjs --compile",
    "deploy:native:encoder": "node scripts/deploy-native.mjs --deploy",
    "deploy:native:vector": "node scripts/deploy-vector-native.mjs --deploy",
    "deploy:rust-binaries": "node scripts/deploy-rust-binaries.mjs",
    "deploy:rust-binaries:all": "node scripts/deploy-rust-binaries.mjs --platform all",
    "rebuild:rust-binaries": "node scripts/rebuild-rust-binaries.mjs",
    "rebuild:rust-binaries:all": "node scripts/rebuild-rust-binaries.mjs --platform all"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.14.1-beta.2",
    "agentkeepalive": "^4.2.1",
    "better-sqlite3": "12.8.0",
    "node-pty": "^1.1.0",
    "openai": "^4.104.0",
    "qrcode-terminal": "^0.12.0",
    "usearch": "2.25.1"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "4.2.0",
    "mysql2": "^3.22.5",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
