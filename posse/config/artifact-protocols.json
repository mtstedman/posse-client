{
  "image": {
    "provider": "grok",
    "model": "grok-imagine-image",
    "allowed_formats": [
      ".png",
      ".jpg",
      ".jpeg",
      ".webp"
    ],
    "allowed_manifest_files": [
      "manifest.json",
      "manifest.md",
      "manifest.txt",
      "manifest-*.json",
      "manifest-*.md",
      "manifest-*.txt"
    ],
    "default_format": ".png",
    "max_outputs": 4,
    "require_prompt": true,
    "output_validation": {
      "min_files": 1,
      "min_bytes": 1024
    }
  },
